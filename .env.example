# nostr-commerce-skill — Environment Variables
# Copy to .env and fill in. NEVER commit .env.

# ─── Lightning Wallet (NWC) ───────────────────────────────────────────────────
# Required for: Scenario 7 (payments), 8 (escrow), 13-14 (zaps)
#
# How to get your NWC connection URL:
#   1. Go to https://albyhub.com and create an account
#   2. Connect a Lightning node (or use Alby's hosted option)
#   3. App Connections → New Connection
#   4. Set a SPENDING BUDGET (start with 10,000 sats = ~$5)
#      This is your blast radius if the URL is ever compromised
#   5. Copy the nostr+walletconnect:// URL below
#
NWC_CONNECTION_URL=nostr+walletconnect://REPLACE_WITH_YOUR_URL?relay=wss://relay.getalby.com/v1&secret=REPLACE_WITH_SECRET

# ─── Merchant Identity ────────────────────────────────────────────────────────
# Required for: publishing listings, signing orders, all merchant-side operations
#
# Generate a new key:
#   node -e "
#     import { generateSecretKey } from 'nostr-tools';
#     import { nsecEncode } from 'nostr-tools/nip19';
#     const sk = generateSecretKey();
#     console.log('nsec:', nsecEncode(sk));
#     console.log('pubkey:', import('nostr-tools').then(m => console.log(m.getPublicKey(sk))));
#   "
#
# SECURITY: Treat this like a bank password. Never commit. Never log.
# Back it up in a password manager immediately after generating.
#
MERCHANT_NSEC=nsec1REPLACE_WITH_YOUR_PRIVATE_KEY

# ─── LND Node (Required for Escrow — Scenario 8) ─────────────────────────────
# Only needed if using escrow with LndEscrowBackend.
# Not needed for standard payments (NWC handles those).
#
LND_HOST=https://your-lnd-node:8080
LND_MACAROON_HEX=REPLACE_WITH_ADMIN_MACAROON_IN_HEX
# Get hex macaroon: xxd -plain ~/.lnd/data/chain/bitcoin/mainnet/admin.macaroon | tr -d '\n'

# ─── Alby Hub (Alternative Escrow Backend) ────────────────────────────────────
# Only needed if using AlbyHubEscrowBackend instead of LndEscrowBackend.
#
ALBY_HUB_URL=https://your-hub.getalby.com
ALBY_HUB_TOKEN=REPLACE_WITH_HUB_TOKEN

# ─── Escrow Safety ────────────────────────────────────────────────────────────
# Set to "true" ONLY after connecting a persistent database for escrow sessions.
# Without this, server restarts will lose in-flight escrow sessions (fund risk).
# See escrow.ts for the database adapter pattern.
#
ESCROW_STORE_ACKNOWLEDGED=false

# ─── Optional: Custom Relays ──────────────────────────────────────────────────
# Comma-separated relay WebSocket URLs. Defaults are used if not set.
# NOSTR_RELAYS=wss://relay.damus.io,wss://relay.nostr.band,wss://nos.lol,wss://relay.primal.net,wss://nostr.wine
